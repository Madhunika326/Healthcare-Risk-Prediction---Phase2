# Flask Application Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# Flask Configuration
# ============================================
FLASK_ENV=development
FLASK_APP=run.py
SECRET_KEY=your-secret-key-change-in-production-12345678

# ============================================
# Database Configuration
# ============================================
# Development (SQLite)
DATABASE_URL=sqlite:///instance/healthcare_risk.db

# Production (PostgreSQL)
# DATABASE_URL=postgresql://username:password@localhost:5432/healthcare_risk

# ============================================
# ML Models Path
# ============================================
MODELS_PATH=../models

# ============================================
# Server Configuration
# ============================================
PORT=5000
DEBUG=True
HOST=0.0.0.0

# ============================================
# Session Configuration
# ============================================
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=604800

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ============================================
# Email Configuration (for future use)
# ============================================
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password

# ============================================
# Third-Party Services (Optional)
# ============================================
# SENTRY_DSN=your-sentry-dsn
# STRIPE_API_KEY=your-stripe-key

# ============================================
# Feature Flags
# ============================================
ENABLE_REGISTRATION=True
ENABLE_API=True
ENABLE_ADMIN_PANEL=True
ENABLE_EXPORT_PDF=True
ENABLE_EXPORT_CSV=True
